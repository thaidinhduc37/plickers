# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_LAN_IP=localhost

# Database Configuration
DATABASE_URL=sqlite:///./plickers.db
# For MySQL: DATABASE_URL=mysql+pymysql://user:password@localhost/plickers

# Authentication Settings
# SECRET_KEY for JWT tokens (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-secret-key-here-change-in-production

# Admin User Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=rcv2024

# Auto-Login Mode (Development Only)
# Set to True for development (bypasses authentication)
# Set to False for production (requires valid login)
AUTO_LOGIN=True