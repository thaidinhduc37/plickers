SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480
DATABASE_URL=sqlite:///./rcv.db
# Địa chỉ IP máy chạy backend trên LAN (để CV service biết gọi về đâu)
SERVER_LAN_IP=192.168.1.100
SERVER_PORT=8000
# Danh sách IP được phép gọi /api/scan/submit (CV service)
ALLOWED_CV_IPS=127.0.0.1,192.168.1.0/24
